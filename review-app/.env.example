# どのデータ層を使うか: mock（既定・SharePoint 不要でそのまま動く）| sharepoint | dataverse
VITE_DATA_ADAPTER=mock

# --- SharePoint / Entra（VITE_DATA_ADAPTER=sharepoint のとき必須）---
# Entra アプリ登録の Application (client) ID
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# テナント ID（顧客テナント）
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# サインイン後のリダイレクト先（開発時は http://localhost:5173）
VITE_ENTRA_REDIRECT_URI=http://localhost:5173

# SharePoint サイト（例: contoso.sharepoint.com,{siteGuid},{webGuid} または host:/sites/xxx 形式）
VITE_SP_SITE_ID=contoso.sharepoint.com,00000000-0000-0000-0000-000000000000,00000000-0000-0000-0000-000000000000
# 各リストの表示名（provisioning/sharepoint-lists.ps1 で作られる名前と一致させる）
VITE_SP_LIST_DOCUMENTS=Documents
VITE_SP_LIST_SEGMENTS=Segments
VITE_SP_LIST_DECISIONS=Decisions
VITE_SP_LIST_CONFIG=ReviewConfig
